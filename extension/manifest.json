{
  "manifest_version": 3,
  "name": "Anti-Cyberbullying (Reader)",
  "version": "0.1.0",
  "description": "Detects toxic Reddit comments in real time.",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://cdn.jsdelivr.net/*",
    "https://reddit.com/*",
    "https://*.reddit.com/*",
    "https://www.reddit.com/*",
    "https://old.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["models/*", "utils/ort.min.js", "utils/bert-tokenizer.js", "offscreen.html", "offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://reddit.com/*",
        "https://*.reddit.com/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ],
      "js": [
        "utils/reddit-parser.js",
        "utils/model-client.js",
        "utils/detox-rewriter.js",
        "ui/comment-highlighter.js",
        "ui/thread-heatmap.js",
        "content_scripts/reddit-reader.js",
        "content_scripts/typing-prevention.js"
      ],
      "css": [
        "css/style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
